rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function requesterUserDocExists() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function requesterAccountRole() {
      return requesterUserDocExists()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountRole
        : null;
    }

    function hasWorkspaceAccessRole(allowedRoles) {
      return requesterAccountRole() in allowedRoles;
    }

    function canManageWorkspaceUsers() {
      return isAdmin() || hasWorkspaceAccessRole(['owner', 'manager', 'administrator']);
    }

    function canEditWorkspaceContent() {
      return isAdmin() || hasWorkspaceAccessRole(['owner', 'manager', 'administrator', 'editor']);
    }

    function canAssignAccountRole(targetRole) {
      return isAdmin() ||
        (requesterAccountRole() == 'owner' && targetRole in ['owner', 'manager', 'administrator', 'editor', 'commentator', 'viewer']) ||
        (requesterAccountRole() == 'manager' && targetRole in ['manager', 'administrator', 'editor', 'commentator', 'viewer']) ||
        (requesterAccountRole() == 'administrator' && targetRole in ['editor', 'commentator', 'viewer']);
    }

    function isTherapistOfUser(userId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(userId)) &&
        get(/databases/$(database)/documents/users/$(userId)).data.therapistIds.hasAny([request.auth.uid]);
    }

    function incomingDataMatchesOwner(userId) {
      return request.resource.data.userId == userId;
    }

    function ownerIsImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    function hasValidRoleFields() {
      return (!('role' in request.resource.data) || request.resource.data.role in ['guest', 'patient', 'professional', 'clinic']) &&
        (!('userRole' in request.resource.data) || request.resource.data.userRole in ['clinic', 'professional', 'patient']) &&
        (!('accountRole' in request.resource.data) || request.resource.data.accountRole in ['owner', 'manager', 'administrator', 'editor', 'commentator', 'viewer']) &&
        (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin is bool);
    }

    function hasValidPinnedPatientModulesField() {
      return (!('pinnedPatientModules' in request.resource.data) || request.resource.data.pinnedPatientModules is list);
    }

    function hasDefaultPatientPinnedModules() {
      return request.resource.data.pinnedPatientModules == ['check-in', 'observer', 'progress'];
    }

    function hasNoPinnedPatientModules() {
      return !('pinnedPatientModules' in request.resource.data) || request.resource.data.pinnedPatientModules.size() == 0;
    }

    function hasValidLatestCheckInSummary() {
      return (!('latestCheckInScore' in request.resource.data) || request.resource.data.latestCheckInScore is number) &&
        (!('latestCheckInLevel' in request.resource.data) || request.resource.data.latestCheckInLevel in ['healthy', 'mild', 'moderate', 'severe']) &&
        (!('latestCheckInAt' in request.resource.data) || request.resource.data.latestCheckInAt == null || request.resource.data.latestCheckInAt is timestamp) &&
        (!('latestCheckInNote' in request.resource.data) || request.resource.data.latestCheckInNote is string) &&
        (!('latestCheckInSelfHarmRisk' in request.resource.data) || request.resource.data.latestCheckInSelfHarmRisk is bool) &&
        (!('latestCheckInNeedsProfessionalSupport' in request.resource.data) || request.resource.data.latestCheckInNeedsProfessionalSupport is bool) &&
        (!('latestCheckInUrgentSupport' in request.resource.data) || request.resource.data.latestCheckInUrgentSupport is bool);
    }

    function hasValidLatestThoughtSummary() {
      return (!('latestThoughtAt' in request.resource.data) || request.resource.data.latestThoughtAt == null || request.resource.data.latestThoughtAt is timestamp) &&
        (!('latestThoughtEmotion' in request.resource.data) || request.resource.data.latestThoughtEmotion is string) &&
        (!('latestThoughtIntensity' in request.resource.data) || request.resource.data.latestThoughtIntensity is number) &&
        (!('latestThoughtLabel' in request.resource.data) || request.resource.data.latestThoughtLabel is string) &&
        (!('latestThoughtPreview' in request.resource.data) || request.resource.data.latestThoughtPreview is string) &&
        (!('latestThoughtIsIntrusive' in request.resource.data) || request.resource.data.latestThoughtIsIntrusive is bool);
    }

    function ownerSafeProfileCreate(userId) {
      return isOwner(userId) &&
        request.resource.data.id == userId &&
        request.resource.data.accountRole == 'viewer' &&
        request.resource.data.isAdmin == false &&
        (
          (request.resource.data.role == 'guest' && request.resource.data.userRole == 'patient' && hasNoPinnedPatientModules()) ||
          (request.resource.data.role == 'patient' && request.resource.data.userRole == 'patient' && hasDefaultPatientPinnedModules())
        );
    }

    function ownerSafeProfileUpdate() {
      return request.resource.data.role == resource.data.role &&
        request.resource.data.userRole == resource.data.userRole &&
        request.resource.data.accountRole == resource.data.accountRole &&
        request.resource.data.isAdmin == resource.data.isAdmin &&
        request.resource.data.pinnedPatientModules == resource.data.pinnedPatientModules;
    }

    function privilegedProfileFieldsAllowedByRequester() {
      return hasValidRoleFields() &&
        hasValidPinnedPatientModulesField() &&
        canAssignAccountRole(request.resource.data.accountRole);
    }

    function hasValidModuleOverrideShape() {
      return request.resource.data.manualAllow is list &&
        request.resource.data.manualDeny is list &&
        request.resource.data.pinnedPatientModules is list;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isTherapistOfUser(userId) || isAdmin() || canManageWorkspaceUsers();
      allow list: if isAdmin() || canManageWorkspaceUsers();
      allow create: if request.resource.data.id == userId &&
        hasValidRoleFields() &&
        hasValidPinnedPatientModulesField() &&
        hasValidLatestCheckInSummary() &&
        hasValidLatestThoughtSummary() &&
        (
          ownerSafeProfileCreate(userId) ||
          (isAdmin() &&
            request.resource.data.role in ['guest', 'patient', 'professional', 'clinic'] &&
            request.resource.data.userRole in ['clinic', 'professional', 'patient'] &&
            request.resource.data.accountRole in ['owner', 'manager', 'administrator', 'editor', 'commentator', 'viewer'])
        );
      allow update: if request.resource.data.id == resource.data.id &&
        hasValidRoleFields() &&
        hasValidPinnedPatientModulesField() &&
        hasValidLatestCheckInSummary() &&
        hasValidLatestThoughtSummary() &&
        (
          (isOwner(userId) && ownerSafeProfileUpdate()) ||
          (canManageWorkspaceUsers() && privilegedProfileFieldsAllowedByRequester())
        );
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /therapists/{therapistId} {
      allow get: if isOwner(therapistId) || isAdmin() || canManageWorkspaceUsers();
      allow list: if false;
      allow create: if isOwner(therapistId) || canManageWorkspaceUsers();
      allow update: if isExistingOwner(therapistId) || canManageWorkspaceUsers();
      allow delete: if isExistingOwner(therapistId) || canManageWorkspaceUsers();
    }

    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /workspaceSettings/{settingId} {
      allow get, list: if canManageWorkspaceUsers();
      allow create, update: if canManageWorkspaceUsers();
      allow delete: if isAdmin() || requesterAccountRole() == 'owner';
    }

    match /rolePolicies/{roleId} {
      allow get, list: if canManageWorkspaceUsers();
      allow create, update: if canManageWorkspaceUsers();
      allow delete: if isAdmin() || requesterAccountRole() == 'owner';
    }

    match /moduleCatalog/{moduleId} {
      allow get, list: if canManageWorkspaceUsers();
      allow create, update: if canManageWorkspaceUsers();
      allow delete: if isAdmin() || requesterAccountRole() == 'owner';
    }

    match /accessRules/{ruleId} {
      allow get, list: if canManageWorkspaceUsers();
      allow create, update: if canManageWorkspaceUsers();
      allow delete: if isAdmin() || requesterAccountRole() == 'owner';
    }

    match /userModuleOverrides/{userId} {
      allow get: if isOwner(userId) || canManageWorkspaceUsers();
      allow list: if canManageWorkspaceUsers();
      allow create, update: if canManageWorkspaceUsers() && hasValidModuleOverrideShape();
      allow delete: if isAdmin() || requesterAccountRole() == 'owner';
    }

    match /resolvedAccess/{userId} {
      allow get: if isOwner(userId) || canManageWorkspaceUsers();
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /users/{userId}/thoughtRecords/{recordId} {
      allow get, list: if isOwner(userId) || isTherapistOfUser(userId) || isAdmin() || canManageWorkspaceUsers();
      allow create: if isOwner(userId) && incomingDataMatchesOwner(userId);
      allow update: if isExistingOwner(userId) && ownerIsImmutable();
      allow delete: if isExistingOwner(userId) || canManageWorkspaceUsers();
    }

    match /users/{userId}/exposureMissions/{missionId} {
      allow get, list: if isOwner(userId) || isTherapistOfUser(userId) || isAdmin() || canManageWorkspaceUsers();
      allow create: if (isOwner(userId) || isTherapistOfUser(userId) || canManageWorkspaceUsers()) && incomingDataMatchesOwner(userId);
      allow update: if (isExistingOwner(userId) || isTherapistOfUser(userId) || canManageWorkspaceUsers()) && ownerIsImmutable();
      allow delete: if isExistingOwner(userId) || canManageWorkspaceUsers();
    }

    match /users/{userId}/mental_checkups/{checkupId} {
      allow get, list: if isOwner(userId) || isTherapistOfUser(userId) || isAdmin() || canManageWorkspaceUsers();
      allow create: if isOwner(userId) && incomingDataMatchesOwner(userId);
      allow update: if isExistingOwner(userId) && ownerIsImmutable();
      allow delete: if isExistingOwner(userId) || canManageWorkspaceUsers();
    }

    match /users/{userId}/progressEvents/{eventId} {
      allow get, list: if isOwner(userId) || isTherapistOfUser(userId) || isAdmin() || canManageWorkspaceUsers();
      allow create: if isOwner(userId) && incomingDataMatchesOwner(userId);
      allow update: if isExistingOwner(userId) && ownerIsImmutable();
      allow delete: if isExistingOwner(userId) || isAdmin() || canManageWorkspaceUsers();
    }

    match /users/{userId}/medicalSupportPlans/{planId} {
      allow get, list: if isOwner(userId) || isTherapistOfUser(userId) || isAdmin() || canManageWorkspaceUsers();
      allow create: if (isOwner(userId) || isTherapistOfUser(userId) || isAdmin() || canManageWorkspaceUsers()) && incomingDataMatchesOwner(userId);
      allow update: if (isExistingOwner(userId) || isTherapistOfUser(userId) || isAdmin() || canManageWorkspaceUsers()) && ownerIsImmutable();
      allow delete: if isExistingOwner(userId) || isAdmin() || canManageWorkspaceUsers();
    }

    match /users/{userId}/medicationPrescriptions/{prescriptionId} {
      allow get, list: if isOwner(userId) || isTherapistOfUser(userId) || isAdmin() || canManageWorkspaceUsers();
      allow create: if (isOwner(userId) || isTherapistOfUser(userId) || isAdmin() || canManageWorkspaceUsers()) && incomingDataMatchesOwner(userId);
      allow update: if (isExistingOwner(userId) || isTherapistOfUser(userId) || isAdmin() || canManageWorkspaceUsers()) && ownerIsImmutable();
      allow delete: if isExistingOwner(userId) || isAdmin() || canManageWorkspaceUsers();
    }

    match /exerciseTemplates/{templateId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if canEditWorkspaceContent();
    }

    match /users/{userId}/exerciseLogs/{logId} {
      allow get, list: if isOwner(userId) || isTherapistOfUser(userId) || isAdmin() || canManageWorkspaceUsers();
      allow create: if isOwner(userId) && incomingDataMatchesOwner(userId);
      allow update: if isExistingOwner(userId) && ownerIsImmutable();
      allow delete: if isExistingOwner(userId) || canManageWorkspaceUsers();
    }

    match /users/{userId}/mentalCombatEvents/{eventId} {
      allow get, list: if isOwner(userId) || isTherapistOfUser(userId) || isAdmin() || canManageWorkspaceUsers();
      allow create: if isOwner(userId) && incomingDataMatchesOwner(userId);
      allow update: if isExistingOwner(userId) && ownerIsImmutable();
      allow delete: if isExistingOwner(userId) || canManageWorkspaceUsers();
    }

    match /users/{userId}/anxietyLogs/{logId} {
      allow get, list: if isOwner(userId) || isTherapistOfUser(userId) || isAdmin() || canManageWorkspaceUsers();
      allow create: if isOwner(userId) && incomingDataMatchesOwner(userId);
      allow update: if isExistingOwner(userId) && ownerIsImmutable();
      allow delete: if isExistingOwner(userId) || canManageWorkspaceUsers();
    }

    match /achievements/{achievementId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if canEditWorkspaceContent();
    }

    match /users/{userId}/userAchievements/{userAchievementId} {
      allow get, list: if isOwner(userId) || isTherapistOfUser(userId) || isAdmin() || canManageWorkspaceUsers();
      allow create: if (isAdmin() || canEditWorkspaceContent()) && incomingDataMatchesOwner(userId);
      allow update, delete: if false;
    }
  }
}
